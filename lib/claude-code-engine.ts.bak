    description: 'Quality audit: accessibility (WCAG 2.1 AA), semantic HTML validation, color contrast ratios, keyboard navigation, ARIA attributes, cross-browser.',
    expertise: ['accessibility', 'wcag', 'aria', 'contrast', 'keyboard-nav', 'validation', 'cross-browser'],
    modelTier: 'medium',
    priority: 7,
  },
  researcher: {
    name: 'Researcher Agent',
