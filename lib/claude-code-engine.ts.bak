    modelTier: 'complex',
    priority: 1,
  },
  designer: {
    name: 'Designer Agent',
    description: 'Visual design system: color palette, typography scale, spacing rhythm, border radii, shadows, gradients. Ensures visual cohesion and brand consistency.',
    expertise: ['colors', 'fonts', 'spacing', 'shadows', 'gradients', 'visual-hierarchy', 'brand', 'aesthetics'],
    modelTier: 'complex',
    priority: 2,
  },
  coder: {
