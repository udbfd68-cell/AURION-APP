/**
 * Analyze a user request and determine which subsystems should be involved.
 * This is the "thinking" step — Jarvis's brain deciding what tools to use.
 */
export function analyzeRequest(prompt: string, context: Partial<JarvisContext>): {
  subsystems: SubSystem[];
  reasoning: string;
  suggestedPlan: string[];
} {
  const lower = prompt.toLowerCase();
  const subsystems: Set<SubSystem> = new Set();
  const plan: string[] = [];

  // Always include the primary AI model
  subsystems.add('system-prompts');

  // Clone detection
  if (/clone|copy|replicate|reproduce|pixel.?perfect/i.test(lower) && /https?:\/\/|url|website|site/i.test(lower)) {
    subsystems.add('firecrawl');
    subsystems.add('clone');
    subsystems.add('anthropic');
    plan.push('Scrape target URL with Firecrawl for design tokens');
    plan.push('Extract branding: colors, fonts, typography, screenshots');
    plan.push('Generate pixel-perfect clone via Claude with design system injection');
    plan.push('Run quality gates to verify completeness');
  }

  // Research-heavy requests
  if (/research|analyze|study|compare|best.?practices|benchmark|audit/i.test(lower)) {
    subsystems.add('notebooklm');
    plan.push('Deep research via NotebookLM on the topic');
    plan.push('Inject research insights into generation context');
  }

  // Design/UI requests
  if (/design|ui|ux|layout|component|screen|wireframe|mockup|prototype/i.test(lower)) {
    subsystems.add('stitch');
    subsystems.add('21stdev');
    subsystems.add('ui-ux-pro-max');
    subsystems.add('reactbits');
    plan.push('Analyze design requirements against 67 UI styles');
    plan.push('Select optimal palette from 96 industry options');
    plan.push('Generate screen designs via Stitch with design constraints');
    plan.push('Apply ReactBits component patterns for premium interactivity');
  }

  // Full website generation
  if (/website|landing|page|portfolio|saas|dashboard|app|ecommerce|shop/i.test(lower)) {
    subsystems.add('anthropic');
    subsystems.add('templates');
    subsystems.add('reactbits');
    subsystems.add('21stdev');
    subsystems.add('motionsite');
    subsystems.add('media');
    subsystems.add('ui-ux-pro-max');
    plan.push('Select closest template from 22 premium references');
    plan.push('Choose font pairing + color palette by industry');
    plan.push('Generate with Claude 128K context for complete output');
    plan.push('Apply premium effects: aurora, glass, animations');
    plan.push('Inject video backgrounds from MotionSite library');
    plan.push('Run quality gates + responsive verification');
  }

  // Video/media requests
  if (/video|animation|media|image|photo|visual|hero.?image|product.?shot/i.test(lower)) {
    subsystems.add('media');
    plan.push('Generate media assets via LTX Video / Gemini Images');
  }

  // Deploy requests
  if (/deploy|publish|live|production|ship|launch/i.test(lower)) {
    subsystems.add('vercel');
    subsystems.add('quality-gates');
    plan.push('Validate output with quality gates');
    plan.push('Deploy to Vercel production');
    plan.push('Verify deployment is live');
  }

  // GitHub requests
  if (/github|git|push|commit|repo|repository/i.test(lower)) {
    subsystems.add('github');
    plan.push('Push code to GitHub repository');
  }

  // Terminal/build requests
  if (/install|build|npm|yarn|package|command|terminal|lint|test/i.test(lower)) {
    subsystems.add('terminal');
    plan.push('Execute terminal commands');
  }

  // Screenshot-to-code (image analysis)
  if (/screenshot|image|picture|photo.*code|recreate|reproduce/i.test(lower)) {
    subsystems.add('gemini');
    plan.push('Analyze screenshot via Gemini vision');
    plan.push('Extract layout, colors, typography, components');
    plan.push('Generate pixel-perfect HTML reproduction');
  }

  // Always include quality for code generation
  if (subsystems.has('anthropic') || subsystems.has('gemini')) {
    subsystems.add('quality-gates');
  }

  // Default: at least use Claude for generation
  if (subsystems.size <= 1) {
    subsystems.add('anthropic');
    subsystems.add('reactbits');
    subsystems.add('templates');
    plan.push('Generate with Claude + ReactBits component patterns');
  }

  const systemList = Array.from(subsystems);
  const reasoning = `Jarvis activating ${systemList.length} subsystems: ${systemList.map(s => SUBSYSTEM_CAPABILITIES[s].name).join(', ')}`;

  return { subsystems: systemList, reasoning, suggestedPlan: plan };
}

/**
 * Create a structured execution plan from analyzed subsystems.
 */
export function createPlan(goal: string, analysis: ReturnType<typeof analyzeRequest>): JarvisPlan {
  const tasks: JarvisTask[] = analysis.suggestedPlan.map((step, i) => ({
    id: `task-${i + 1}`,
    name: step.split(' ').slice(0, 4).join(' '),
    description: step,
    subsystems: analysis.subsystems.filter(s => {
      const cap = SUBSYSTEM_CAPABILITIES[s];
      return step.toLowerCase().includes(cap.name.toLowerCase().split(' ')[0].toLowerCase());
    }),
    status: 'pending' as const,
    priority: i + 1,
    dependencies: i > 0 ? [`task-${i}`] : undefined,
  }));

  return {
    id: `plan-${Date.now().toString(36)}`,
    goal,
    tasks,
    status: 'planning',
    created: Date.now(),
    completedTasks: 0,
    totalTasks: tasks.length,
  };
}

/**
 * Build the Jarvis-enhanced system prompt that includes orchestrator context.
 * This is injected into every Claude Code generation for maximum intelligence.
 */
export function buildJarvisSystemContext(
  activeSubsystems: SubSystem[],
  plan?: JarvisPlan,
): string {
  const sections: string[] = [];

  sections.push(`[JARVIS ORCHESTRATOR — ACTIVE]`);
  sections.push(`You are operating in Jarvis Mode — the central brain of Aurion.`);
  sections.push(`You have access to ${Object.keys(SUBSYSTEM_CAPABILITIES).length} subsystems and the collective intelligence of 17 world-class app builders.`);
  sections.push('');

  // Active subsystems
  sections.push(`## Active Subsystems (${activeSubsystems.length}):`);
  for (const sys of activeSubsystems) {
    const cap = SUBSYSTEM_CAPABILITIES[sys];
    sections.push(`- **${cap.name}**: ${cap.description}`);
    sections.push(`  Actions: ${cap.actions.join(', ')}`);
  }

  // Current plan
  if (plan && plan.tasks.length > 0) {
    sections.push('');
    sections.push(`## Execution Plan: "${plan.goal}"`);
    for (const task of plan.tasks) {
      const icon = task.status === 'completed' ? '✅' : task.status === 'running' ? '🔄' : task.status === 'failed' ? '❌' : '⏳';
      sections.push(`${icon} [${task.id}] ${task.description}`);
    }
    sections.push(`Progress: ${plan.completedTasks}/${plan.totalTasks} tasks completed`);
  }

  // Available integrations
  sections.push('');
  sections.push('## Available Actions (use via <<ACTION>> tags):');
  sections.push('- <<FILE:path>> — Create/update files');
  sections.push('- <<TERMINAL:command>> — Execute commands');
  sections.push('- <<DEPLOY>> — Deploy to Vercel');
  sections.push('- <<CLONE:url>> — Clone a website');
  sections.push('- <<STITCH:action|params>> — Generate UI via Stitch');
  sections.push('- <<RESEARCH:topic>> — Research via NotebookLM');
  sections.push('- <<GEMINI_IMAGE:id|prompt>> — Generate AI image');
  sections.push('- <<LTX_VIDEO:id|prompt>> — Generate AI video');
  sections.push('- <<QUALITY_CHECK>> — Run output quality gates');

  sections.push('');
  sections.push('## Orchestration Rules:');
  sections.push('1. THINK before acting — analyze which subsystems serve the goal');
  sections.push('2. PLAN multi-step tasks — break into sequential/parallel subtasks');
  sections.push('3. USE the right tool — Claude for complex gen, Gemini for vision, Stitch for UI design');
  sections.push('4. VERIFY every output — run quality gates before declaring done');
  sections.push('5. ITERATE on failures — classify errors, apply smart retry, fix root cause');
  sections.push('6. COMPLETE everything — generate full code, no truncation, no placeholders');
  sections.push('[/JARVIS ORCHESTRATOR]');

  return sections.join('\n');
}

/**
 * Format a Jarvis status report for the UI panel.
 */
export function formatJarvisStatus(plan: JarvisPlan): string {
  const pct = plan.totalTasks > 0 ? Math.round((plan.completedTasks / plan.totalTasks) * 100) : 0;
  const lines: string[] = [];
  lines.push(`🧠 Jarvis • ${plan.status.toUpperCase()}`);
  lines.push(`Goal: ${plan.goal}`);
  lines.push(`Progress: ${plan.completedTasks}/${plan.totalTasks} (${pct}%)`);
  lines.push('');
  for (const task of plan.tasks) {
    const icon = task.status === 'completed' ? '✅' : task.status === 'running' ? '⚡' : task.status === 'failed' ? '❌' : '○';
    lines.push(`${icon} ${task.description}${task.error ? ` — Error: ${task.error}` : ''}`);
  }
  return lines.join('\n');
}

// ═══════════════════════════════════════════════════════════════════════════════
// RUFLO MULTI-AGENT ORCHESTRATION ENGINE
// Inspired by https://github.com/ruvnet/ruflo — Enterprise AI Agent Orchestration
// Adapted for Aurion's app builder pipeline:
//   Swarm coordination, specialized agents, intelligent routing,
//   anti-drift checkpoints, consensus, 3-tier model routing, pattern memory
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Agent Types — Specialized virtual agents for app building ───────────────

export type AgentRole =
  | 'architect'     // System design, layout structure, component hierarchy
  | 'designer'      // Visual design, colors, typography, spacing, aesthetics
  | 'coder'         // HTML/CSS/JS generation, implementation
  | 'animator'      // Motion, transitions, scroll effects, GSAP, Framer
  | 'responsive'    // Multi-viewport adaptation, mobile-first, breakpoints
  | 'optimizer'     // Performance, lighthouse, critical CSS, lazy loading
  | 'reviewer'      // Code review, quality checks, accessibility audit
  | 'researcher'    // Market analysis, competitor study, design trends
  | 'content'       // Copywriting, SEO text, microcopy, CTAs
  | 'security';     // XSS prevention, CSP headers, input sanitization

export interface Agent {
  id: string;
  role: AgentRole;
  name: string;
  expertise: string[];
  status: 'idle' | 'working' | 'done' | 'failed';
  currentTask?: string;
  successRate: number;    // 0-1, updated from pattern memory
  totalTasks: number;
  successfulTasks: number;
}

/** Agent capability definitions — what each agent role specializes in */
export const AGENT_CAPABILITIES: Record<AgentRole, {
  name: string;
  description: string;
  expertise: string[];
  modelTier: ModelTier;
  priority: number;       // execution order within swarm (1 = first)
}> = {
  architect: {
