    description: 'Generates production-quality HTML/CSS/JS. Semantic markup, CSS custom properties, vanilla JS interactivity. Single-file output, no frameworks.',
    expertise: ['html', 'css', 'javascript', 'dom', 'events', 'forms', 'semantic-markup'],
    modelTier: 'complex',
    priority: 3,
  },
  animator: {
    name: 'Animator Agent',
    description: 'Motion design: scroll-triggered animations, page transitions, hover effects, parallax, GSAP/CSS keyframes, IntersectionObserver reveals.',
    expertise: ['animation', 'transitions', 'gsap', 'scroll-effects', 'parallax', 'keyframes', 'intersection-observer'],
    modelTier: 'medium',
    priority: 5,
  },
  responsive: {
    name: 'Responsive Agent',
    description: 'Multi-viewport adaptation: mobile-first breakpoints, fluid typography, responsive images, touch targets, hamburger nav, viewport units.',
    expertise: ['breakpoints', 'mobile', 'tablet', 'fluid-typography', 'responsive-images', 'media-queries'],
    modelTier: 'medium',
    priority: 4,
  },
  optimizer: {
    name: 'Optimizer Agent',
    description: 'Performance: critical CSS inlining, image lazy loading, font-display swap, preconnect hints, minification strategies, Core Web Vitals.',
    expertise: ['performance', 'lazy-loading', 'critical-css', 'lighthouse', 'web-vitals', 'compression'],
    modelTier: 'simple',
