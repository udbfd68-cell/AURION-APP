// ─── 3-Tier Model Routing — Simple → cheap/fast, Complex → powerful ──────────

export type ModelTier = 'simple' | 'medium' | 'complex';

export interface ModelRoute {
  tier: ModelTier;
  provider: string;
  model: string;
  maxTokens: number;
  costPerMToken: number;
  latencyMs: number;
}

/** Route a task to the optimal model tier based on complexity */
export function routeToModelTier(taskComplexity: number): ModelTier {
  if (taskComplexity < 0.3) return 'simple';
  if (taskComplexity < 0.7) return 'medium';
  return 'complex';
}

/** Estimate task complexity (0-1) based on requirements */
export function estimateTaskComplexity(description: string, sectionCount: number = 0): number {
  let complexity = 0.3; // baseline

  // Structural complexity
  if (sectionCount > 8) complexity += 0.15;
  if (sectionCount > 15) complexity += 0.1;

  // Feature complexity signals
  const complexSignals = [
    [/animation|gsap|parallax|scroll.?effect/i, 0.1],
    [/responsive|mobile.?first|breakpoint/i, 0.08],
    [/form|input|validation|interactive/i, 0.08],
    [/dark.?mode|theme.?switch/i, 0.06],
    [/video|media|canvas|webgl|three\.?js/i, 0.12],
    [/e.?commerce|cart|checkout|payment/i, 0.15],
    [/dashboard|chart|data.?viz/i, 0.12],
    [/auth|login|signup|session/i, 0.1],
    [/real.?time|websocket|sse/i, 0.1],
    [/multi.?page|spa|routing/i, 0.08],
  ] as const;

  for (const [pattern, weight] of complexSignals) {
    if (pattern.test(description)) complexity += weight;
  }

  return Math.min(1, complexity);
}

// ─── Swarm Topologies — How agents coordinate ────────────────────────────────

export type SwarmTopology = 'hierarchical' | 'mesh' | 'pipeline' | 'star';

export interface SwarmConfig {
  topology: SwarmTopology;
  maxAgents: number;
  antiDrift: boolean;          // Enable checkpoint verification
  consensusThreshold: number;  // 0-1, agreement needed for decisions
  checkpointInterval: number;  // Verify alignment every N tasks
}

export const DEFAULT_SWARM_CONFIG: SwarmConfig = {
  topology: 'hierarchical',
  maxAgents: 8,
  antiDrift: true,
  consensusThreshold: 0.67,    // 2/3 majority (Byzantine threshold)
  checkpointInterval: 3,
};

// ─── Swarm Task — A unit of work within a swarm ─────────────────────────────

export interface SwarmTask {
  id: string;
  description: string;
  assignedAgent: AgentRole;
  status: 'queued' | 'in-progress' | 'review' | 'done' | 'failed';
  input: string;
  output?: string;
  startedAt?: number;
  completedAt?: number;
  checkpointPassed?: boolean;
  retries: number;
}

// ─── Pattern Memory — Track successful strategies ────────────────────────────
// Ruflo's self-learning: remember what works, route similar tasks better next time

export interface PatternEntry {
  taskType: string;
  agentRole: AgentRole;
  success: boolean;
  complexity: number;
  duration: number;
  qualityScore: number;    // 0-1 from quality gates
  timestamp: number;
}

/** In-memory pattern store (persists per server instance) */
const patternMemory: PatternEntry[] = [];

export function recordPattern(entry: PatternEntry): void {
  patternMemory.push(entry);
  // Keep last 500 patterns to avoid unbounded growth
  if (patternMemory.length > 500) patternMemory.splice(0, patternMemory.length - 500);
}

/** Get the best agent for a task type based on historical success */
export function getBestAgent(taskType: string, fallback: AgentRole): AgentRole {
  const relevant = patternMemory.filter(p => p.taskType === taskType && p.success);
  if (relevant.length < 3) return fallback; // Not enough data

  // Count successes per agent
  const agentScores = new Map<AgentRole, { successes: number; totalQuality: number; count: number }>();
  for (const p of relevant) {
    const existing = agentScores.get(p.agentRole) || { successes: 0, totalQuality: 0, count: 0 };
    existing.successes++;
    existing.totalQuality += p.qualityScore;
    existing.count++;
    agentScores.set(p.agentRole, existing);
  }

  // Find agent with best success rate × quality score
  let best = fallback;
  let bestScore = 0;
  for (const [role, stats] of agentScores) {
    const score = (stats.successes / stats.count) * (stats.totalQuality / stats.count);
    if (score > bestScore) {
      bestScore = score;
      best = role;
    }
  }
  return best;
}

/** Get pattern memory stats for status reporting */
export function getPatternStats(): {
  totalPatterns: number;
  successRate: number;
  topAgents: Array<{ role: AgentRole; successRate: number; avgQuality: number }>;
} {
  const total = patternMemory.length;
  const successes = patternMemory.filter(p => p.success).length;

  const agentMap = new Map<AgentRole, { successes: number; total: number; quality: number }>();
  for (const p of patternMemory) {
    const existing = agentMap.get(p.agentRole) || { successes: 0, total: 0, quality: 0 };
    existing.total++;
    if (p.success) existing.successes++;
    existing.quality += p.qualityScore;
    agentMap.set(p.agentRole, existing);
  }

  const topAgents = Array.from(agentMap.entries())
    .map(([role, stats]) => ({
      role,
      successRate: stats.total > 0 ? stats.successes / stats.total : 0,
      avgQuality: stats.total > 0 ? stats.quality / stats.total : 0,
    }))
    .sort((a, b) => b.successRate * b.avgQuality - a.successRate * a.avgQuality)
    .slice(0, 5);

  return {
    totalPatterns: total,
    successRate: total > 0 ? successes / total : 0,
    topAgents,
  };
}

// ─── Intelligent Task Router — Route tasks to optimal agents ─────────────────
// Ruflo's Q-Learning-inspired routing: analyze task → pick best agent + model tier

export interface RoutingDecision {
  agent: AgentRole;
  modelTier: ModelTier;
  confidence: number;      // 0-1
  reasoning: string;
  alternativeAgents: AgentRole[];
}

/** Analyze a task description and route to the best agent */
export function routeTask(description: string, sectionCount: number = 0): RoutingDecision {
  const lower = description.toLowerCase();
  const complexity = estimateTaskComplexity(description, sectionCount);
  const modelTier = routeToModelTier(complexity);

  // Score each agent role by keyword match
  const scores = new Map<AgentRole, number>();
  for (const [role, cap] of Object.entries(AGENT_CAPABILITIES)) {
    let score = 0;
    for (const keyword of cap.expertise) {
      const regex = new RegExp(keyword.replace(/-/g, '.?'), 'i');
      if (regex.test(lower)) score += 1;
    }
    // Bonus for historical success
    const bestFromMemory = getBestAgent(lower.split(' ').slice(0, 3).join('-'), role as AgentRole);
    if (bestFromMemory === role) score += 0.5;
    scores.set(role as AgentRole, score);
  }

  // Sort by score
  const ranked = Array.from(scores.entries()).sort((a, b) => b[1] - a[1]);
  const topAgent = ranked[0][0];
  const topScore = ranked[0][1];
  const maxPossible = Math.max(...Array.from(scores.values()), 1);
  const confidence = Math.min(1, topScore / maxPossible);

  return {
    agent: topAgent,
    modelTier,
    confidence,
    reasoning: `Task routed to ${AGENT_CAPABILITIES[topAgent].name} (confidence: ${(confidence * 100).toFixed(0)}%, tier: ${modelTier}). Keywords matched: ${AGENT_CAPABILITIES[topAgent].expertise.filter(k => new RegExp(k.replace(/-/g, '.?'), 'i').test(lower)).join(', ')}`,
    alternativeAgents: ranked.slice(1, 4).map(r => r[0]),
  };
}

// ─── Swarm Decomposer — Break complex tasks into agent subtasks ──────────────
// Ruflo's automatic task decomposition: complex goal → parallel/sequential subtasks

export interface SwarmPlan {
  id: string;
  goal: string;
  topology: SwarmTopology;
  tasks: SwarmTask[];
  agents: Agent[];
  config: SwarmConfig;
  status: 'planning' | 'executing' | 'checkpoint' | 'consensus' | 'completed' | 'failed';
  startedAt: number;
  completedAt?: number;
  checkpointResults: Array<{ taskId: string; passed: boolean; notes: string }>;
}

/** Create a spawn of agents based on the task */
function spawnAgents(roles: AgentRole[]): Agent[] {
  return roles.map((role, i) => ({
    id: `agent-${role}-${Date.now().toString(36)}-${i}`,
    role,
    name: AGENT_CAPABILITIES[role].name,
    expertise: AGENT_CAPABILITIES[role].expertise,
    status: 'idle' as const,
    successRate: 1,
    totalTasks: 0,
    successfulTasks: 0,
  }));
}

/** Decompose a website build into swarm tasks assigned to specialized agents */
export function decomposeForSwarm(
  goal: string,
  scrapeData?: { sectionCount?: number; hasAnimations?: boolean; hasForms?: boolean; hasVideo?: boolean },
  config: Partial<SwarmConfig> = {},
): SwarmPlan {
  const cfg = { ...DEFAULT_SWARM_CONFIG, ...config };
  const lower = goal.toLowerCase();
  const tasks: SwarmTask[] = [];
  const neededRoles = new Set<AgentRole>();
  let taskId = 0;

  const addTask = (desc: string, role: AgentRole, input: string = '') => {
    neededRoles.add(role);
    tasks.push({
      id: `swarm-task-${++taskId}`,
      description: desc,
      assignedAgent: role,
      status: 'queued',
      input,
      retries: 0,
    });
  };

  // Phase 1 — Research & Architecture (parallel)
  if (/clone|replicate|copy/i.test(lower)) {
    addTask('Analyze original site structure: sections, navigation, content hierarchy', 'architect');
    addTask('Extract design system: colors, typography, spacing, shadows from scraped data', 'designer');
  } else {
    addTask('Design page architecture: layout strategy, section order, component hierarchy', 'architect');
    addTask('Create design system: palette, typography scale, spacing rhythm, visual tokens', 'designer');
  }

  // Phase 2 — Content & Research (can parallel with design)
  if (/seo|content|copy|marketing/i.test(lower)) {
    addTask('Write SEO-optimized copy: headlines, descriptions, CTAs, meta tags', 'content');
  }
  if (/research|competitor|trend|market/i.test(lower)) {
    addTask('Research competitor designs, industry patterns, current trends', 'researcher');
  }

  // Phase 3 — Core Implementation (sequential after arch + design)
  addTask('Generate complete HTML/CSS/JS implementing the architecture with the design system', 'coder', 'Depends on architect + designer output');

  // Phase 4 — Enhancement layers (parallel after core)
  addTask('Adapt for all viewports: mobile (360px), tablet (768px), desktop (1440px+)', 'responsive');

  if (scrapeData?.hasAnimations || /animat|motion|effect|parallax|gsap/i.test(lower)) {
    addTask('Add scroll animations, hover effects, page transitions, entrance reveals', 'animator');
  }

  // Phase 5 — Quality & Optimization (sequential, after all enhancements)
  addTask('Optimize performance: critical CSS, lazy loading, font-display swap, preconnect', 'optimizer');
  addTask('Audit accessibility: WCAG AA contrast, keyboard nav, ARIA, semantic HTML', 'reviewer');
  addTask('Security hardening: CSP meta tag, rel=noopener, XSS-safe patterns', 'security');

  const agents = spawnAgents(Array.from(neededRoles).slice(0, cfg.maxAgents));

  return {
    id: `swarm-${Date.now().toString(36)}`,
    goal,
    topology: cfg.topology,
    tasks,
    agents,
    config: cfg,
    status: 'planning',
    startedAt: Date.now(),
    checkpointResults: [],
  };
}

// ─── Anti-Drift Checkpoints — Verify agents stay on-task ─────────────────────
// Ruflo's drift prevention: periodic verification that output matches the goal

export interface CheckpointResult {
  passed: boolean;
  score: number;           // 0-1 alignment score
  issues: string[];
  recommendations: string[];
}

/** Verify that an agent's output aligns with the original goal */
export function runCheckpoint(
  goal: string,
  taskDescription: string,
  output: string,
): CheckpointResult {
  const issues: string[] = [];
  const recommendations: string[] = [];
  let score = 1.0;

  // Check output isn't empty or too short
  if (!output || output.length < 50) {
    issues.push('Output is empty or too short');
    score -= 0.5;
  }

  // Check for common drift patterns
  if (/sorry|i can't|i cannot|as an ai/i.test(output)) {
    issues.push('Agent produced refusal/apology instead of content');
    score -= 0.4;
  }
  if (/```/m.test(output) && /<!DOCTYPE/i.test(output)) {
    issues.push('Output contains markdown fences around HTML — should be raw HTML');
    recommendations.push('Strip markdown code fences and output raw HTML only');
    score -= 0.2;
  }
  if (/lorem ipsum|placeholder|example\.com/i.test(output) && !/placeholder/i.test(goal)) {
    issues.push('Output contains placeholder content not requested in the goal');
    score -= 0.15;
  }

  // Check alignment with task description keywords
  const taskKeywords = taskDescription.toLowerCase().split(/\s+/).filter(w => w.length > 4);
  const outputLower = output.toLowerCase();
  const matchedKeywords = taskKeywords.filter(k => outputLower.includes(k));
  const keywordCoverage = taskKeywords.length > 0 ? matchedKeywords.length / taskKeywords.length : 1;
  if (keywordCoverage < 0.3) {
    issues.push(`Low keyword alignment (${(keywordCoverage * 100).toFixed(0)}%) — output may have drifted from task`);
    score -= 0.2;
  }

  // HTML-specific checks for coder output
  if (/html|css|generat|implement/i.test(taskDescription)) {
    if (output.length > 100 && !/<html/i.test(output) && !/<style/i.test(output) && !/<div/i.test(output)) {
      issues.push('Expected HTML output but none detected');
      score -= 0.3;
    }
  }

  return {
    passed: score >= 0.6,
    score: Math.max(0, score),
    issues,
    recommendations,
  };
}

// ─── Consensus — Multi-agent agreement for critical decisions ────────────────
// Ruflo's Byzantine fault tolerance: multiple agents vote on output quality

export interface ConsensusVote {
  agentRole: AgentRole;
  approved: boolean;
  score: number;          // 0-1
  feedback: string;
}

/** Calculate consensus from multiple agent votes */
export function calculateConsensus(
  votes: ConsensusVote[],
  threshold: number = DEFAULT_SWARM_CONFIG.consensusThreshold,
): { approved: boolean; confidence: number; summary: string } {
  if (votes.length === 0) return { approved: true, confidence: 1, summary: 'No votes needed' };

  const approvals = votes.filter(v => v.approved).length;
  const confidence = approvals / votes.length;
  const avgScore = votes.reduce((s, v) => s + v.score, 0) / votes.length;
  const approved = confidence >= threshold;

  const dissenting = votes.filter(v => !v.approved).map(v => `${v.agentRole}: ${v.feedback}`);
  const summary = approved
    ? `Consensus reached: ${approvals}/${votes.length} approved (${(confidence * 100).toFixed(0)}%), avg quality ${(avgScore * 100).toFixed(0)}%`
    : `Consensus FAILED: ${approvals}/${votes.length} approved (need ${(threshold * 100).toFixed(0)}%). Dissent: ${dissenting.join('; ')}`;

  return { approved, confidence, summary };
}

// ─── Swarm Prompt Builder — Generate multi-agent context for AI calls ────────
// Injects swarm orchestration context into generation prompts

export function buildSwarmPrompt(plan: SwarmPlan, currentTask: SwarmTask): string {
  const sections: string[] = [];

  sections.push(`[RUFLO SWARM ORCHESTRATION — ACTIVE]`);
  sections.push(`You are the ${AGENT_CAPABILITIES[currentTask.assignedAgent].name} within a coordinated agent swarm.`);
  sections.push(`Swarm topology: ${plan.topology} | Agents: ${plan.agents.length} | Anti-drift: ${plan.config.antiDrift ? 'ON' : 'OFF'}`);
  sections.push('');

  // Current agent's role and expertise
  const cap = AGENT_CAPABILITIES[currentTask.assignedAgent];
  sections.push(`## Your Role: ${cap.name}`);
  sections.push(cap.description);
  sections.push(`Expertise: ${cap.expertise.join(', ')}`);
  sections.push('');

  // Swarm goal
  sections.push(`## Swarm Goal`);
  sections.push(plan.goal);
  sections.push('');

  // Current task
  sections.push(`## Your Current Task`);
  sections.push(currentTask.description);
  if (currentTask.input) {
    sections.push(`Input context: ${currentTask.input}`);
  }
  sections.push('');

  // Completed tasks by other agents (for context)
  const completedTasks = plan.tasks.filter(t => t.status === 'done' && t.id !== currentTask.id);
  if (completedTasks.length > 0) {
    sections.push(`## Completed by Other Agents (${completedTasks.length})`);
    for (const t of completedTasks) {
      const summary = t.output ? t.output.slice(0, 300) : '(no output)';
      sections.push(`- [${t.assignedAgent}] ${t.description}: ${summary}...`);
    }
    sections.push('');
  }

  // Anti-drift rules
  if (plan.config.antiDrift) {
    sections.push(`## Anti-Drift Rules`);
    sections.push(`1. Stay EXACTLY within your role. Do NOT do other agents' work.`);
    sections.push(`2. Your output will be verified against the swarm goal at checkpoints.`);
    sections.push(`3. If you detect you're going off-task, STOP and refocus on your specific task.`);
    sections.push(`4. Output ONLY what your role requires — nothing more, nothing less.`);
    sections.push('');
  }

  // Pattern memory context
  const stats = getPatternStats();
  if (stats.totalPatterns > 5) {
    sections.push(`## Learning Context`);
    sections.push(`Pattern memory: ${stats.totalPatterns} entries, ${(stats.successRate * 100).toFixed(0)}% success rate`);
    if (stats.topAgents.length > 0) {
      sections.push(`Top performers: ${stats.topAgents.map(a => `${a.role} (${(a.successRate * 100).toFixed(0)}%)`).join(', ')}`);
    }
  }

  sections.push(`[/RUFLO SWARM]`);
  return sections.join('\n');
}

// ─── Swarm Execution — Orchestrate the full multi-agent pipeline ─────────────

export interface SwarmExecutionResult {
  plan: SwarmPlan;
  outputs: Map<string, string>;
  consensus?: { approved: boolean; confidence: number; summary: string };
  patternEntries: PatternEntry[];
  totalDuration: number;
}

/** Execute a swarm plan by running tasks through their assigned agents.
 *  The caller provides an `executeFn` that actually calls the AI model —
 *  this keeps the orchestrator model-agnostic. */
export async function executeSwarm(
  plan: SwarmPlan,
  executeFn: (agentRole: AgentRole, prompt: string, modelTier: ModelTier) => Promise<string>,
  config: Partial<SwarmConfig> = {},
): Promise<SwarmExecutionResult> {
  const cfg = { ...plan.config, ...config };
  const outputs = new Map<string, string>();
  const patterns: PatternEntry[] = [];
  const startTime = Date.now();

  plan.status = 'executing';

  // Group tasks by phase (based on dependencies / priority)
  const phases = groupTasksByPhase(plan.tasks);

  for (const phase of phases) {
    // Execute all tasks in this phase in parallel
    const phaseResults = await executeParallel(
      phase.map(task => ({
        name: task.id,
        fn: async () => {
          task.status = 'in-progress';
          task.startedAt = Date.now();

          const agent = plan.agents.find(a => a.role === task.assignedAgent);
          if (agent) agent.status = 'working';

          const prompt = buildSwarmPrompt(plan, task);
          const tier = AGENT_CAPABILITIES[task.assignedAgent].modelTier;
          const output = await executeFn(task.assignedAgent, prompt, tier);

          task.output = output;
          task.completedAt = Date.now();

          // Anti-drift checkpoint
          if (cfg.antiDrift) {
            const checkpoint = runCheckpoint(plan.goal, task.description, output);
            task.checkpointPassed = checkpoint.passed;
            plan.checkpointResults.push({
              taskId: task.id,
              passed: checkpoint.passed,
              notes: checkpoint.issues.join('; ') || 'OK',
            });

            if (!checkpoint.passed && task.retries < 2) {
              // Retry with drift correction
              task.retries++;
              task.status = 'queued';
              const correctedPrompt = prompt + `\n\n[DRIFT CORRECTION] Previous attempt failed checkpoint: ${checkpoint.issues.join('. ')}. ${checkpoint.recommendations.join('. ')}. Stay focused on your specific task.`;
              const retryOutput = await executeFn(task.assignedAgent, correctedPrompt, tier);
              task.output = retryOutput;
              task.completedAt = Date.now();
            }
          }

          task.status = 'done';
          if (agent) { agent.status = 'done'; agent.totalTasks++; agent.successfulTasks++; }
          outputs.set(task.id, task.output || '');

          // Record pattern
          const entry: PatternEntry = {
            taskType: task.description.split(' ').slice(0, 3).join('-').toLowerCase(),
            agentRole: task.assignedAgent,
            success: task.checkpointPassed !== false,
            complexity: estimateTaskComplexity(task.description),
            duration: (task.completedAt || Date.now()) - (task.startedAt || Date.now()),
            qualityScore: task.checkpointPassed === false ? 0.3 : 0.85,
            timestamp: Date.now(),
          };
          patterns.push(entry);
          recordPattern(entry);

          return output;
        },
        critical: task.assignedAgent === 'coder', // coder is critical path
      })),
      cfg.maxAgents,
    );

    // Check for critical failures
    const criticalFail = phaseResults.find(r => r.error && plan.tasks.find(t => t.id === r.name)?.assignedAgent === 'coder');
    if (criticalFail) {
      plan.status = 'failed';
      break;
    }
  }

  if (plan.status !== 'failed') {
    plan.status = 'completed';
  }
  plan.completedAt = Date.now();

  return {
    plan,
    outputs,
    patternEntries: patterns,
    totalDuration: Date.now() - startTime,
  };
}

/** Group tasks into execution phases based on agent role priority */
function groupTasksByPhase(tasks: SwarmTask[]): SwarmTask[][] {
  const priorityMap: Record<string, number> = {};
  for (const [role, cap] of Object.entries(AGENT_CAPABILITIES)) {
    priorityMap[role] = cap.priority;
  }

  // Group by priority level
  const groups = new Map<number, SwarmTask[]>();
  for (const task of tasks) {
    const priority = priorityMap[task.assignedAgent] ?? 5;
    const existing = groups.get(priority) || [];
    existing.push(task);
    groups.set(priority, existing);
  }

  // Sort phases by priority (lower = earlier)
  return Array.from(groups.entries())
    .sort((a, b) => a[0] - b[0])
    .map(([, tasks]) => tasks);
}

// ─── Swarm Status Reporter — Format swarm progress for UI ────────────────────

export function formatSwarmStatus(plan: SwarmPlan): string {
  const elapsed = plan.completedAt
    ? plan.completedAt - plan.startedAt
    : Date.now() - plan.startedAt;
  const done = plan.tasks.filter(t => t.status === 'done').length;
  const total = plan.tasks.length;
  const pct = total > 0 ? Math.round((done / total) * 100) : 0;

  const lines: string[] = [];
  lines.push(`🐝 Ruflo Swarm • ${plan.topology.toUpperCase()} • ${plan.status.toUpperCase()}`);
  lines.push(`Goal: ${plan.goal}`);
  lines.push(`Agents: ${plan.agents.length} | Tasks: ${done}/${total} (${pct}%) | Time: ${(elapsed / 1000).toFixed(1)}s`);
  lines.push('');

  // Agent status
  for (const agent of plan.agents) {
    const statusIcon = agent.status === 'done' ? '✅' : agent.status === 'working' ? '⚡' : agent.status === 'failed' ? '❌' : '○';
    lines.push(`  ${statusIcon} ${agent.name} (${agent.role})`);
  }
  lines.push('');

  // Task progress
  lines.push('Tasks:');
  for (const task of plan.tasks) {
    const icon = task.status === 'done' ? '✅' : task.status === 'in-progress' ? '🔄' : task.status === 'review' ? '🔍' : task.status === 'failed' ? '❌' : '○';
    const checkpoint = task.checkpointPassed === true ? ' ✓drift' : task.checkpointPassed === false ? ' ⚠drift' : '';
    const retry = task.retries > 0 ? ` (retry ${task.retries})` : '';
    lines.push(`  ${icon} [${task.assignedAgent}] ${task.description}${checkpoint}${retry}`);
  }

  // Pattern stats
  const stats = getPatternStats();
  if (stats.totalPatterns > 0) {
    lines.push('');
    lines.push(`🧠 Pattern Memory: ${stats.totalPatterns} entries, ${(stats.successRate * 100).toFixed(0)}% success`);
  }

  return lines.join('\n');
}
