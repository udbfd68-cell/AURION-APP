# API Keys — set these as environment variables (Vercel > Settings > Environment Variables)
# NEVER hardcode keys in source code.

# Ollama Cloud (FREE unlimited — Qwen3 Coder 480B, DeepSeek V3.2, GLM-5, Devstral 2, etc.)
OLLAMA_API_KEY=your_ollama_api_key_here

# Optional legacy providers (only if directly calling these APIs)
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...
